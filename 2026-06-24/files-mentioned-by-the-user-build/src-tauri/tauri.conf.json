{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeQuest",
  "version": "0.1.0",
  "identifier": "com.codequest.journey",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "CodeQuest",
      "width": 1440,
      "height": 940,
      "minWidth": 940,
      "minHeight": 680,
      "resizable": true,
      "fullscreen": false,
      "decorations": true,
      "transparent": false
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "sql": { "preload": ["sqlite:codequest.db"] }
  }
}
